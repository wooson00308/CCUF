{
  "permissions": {
    "allow": [
      "Bash(unity-mcp-cli *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(ls *)",
      "Bash(python3 *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Read(**/*.unity)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-scene-access.sh \"$TOOL_INPUT\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
